# ══════════════════════════════════════════════════════════════
# PayPerUseAI — Casper Network + x402 Environment Configuration
# ══════════════════════════════════════════════════════════════

# ── AI Provider Keys ─────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=your_gemini_api_key_here
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Casper Network ───────────────────────────────────────────
CASPER_NETWORK=casper:casper-test
CASPER_NODE_RPC_URL=https://rpc.testnet.csprcloud.com

# ── CSPR.cloud Facilitator ───────────────────────────────────
# Get your API key from: https://cspr.build
# 1. Sign up at cspr.build
# 2. Create Application → select Testnet
# 3. Copy the generated access token below
CSPR_X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
CSPR_X402_API_KEY=your-cspr-cloud-api-key-here

# ── CEP-18 Token (Your Custom PayAI Token) ───────────────────
# After running scripts/deploy_token.py, paste the package hash here
# Format: 64 hex characters (NO "hash-" prefix)
CEP18_CONTRACT_PACKAGE_HASH=your_64_char_hex_contract_package_hash_here
CEP18_TOKEN_NAME=PayAIToken
CEP18_TOKEN_SYMBOL=PAIT
CEP18_TOKEN_DECIMALS=2
CEP18_TOKEN_VERSION=1

# ── Platform Receiver Account ─────────────────────────────────
# Your Casper wallet's account hash (from Casper Wallet → copy account hash)
# Format: account-hash-<64hex>  or  00<64hex>  (remove "account-hash-" prefix)
# Example: 00a1b2c3d4...f8e2  (starts with 00 for ED25519, 02 for SECP256K1)
PLATFORM_ACCOUNT_HASH=00your_casper_account_hash_64_chars_here

# ── x402 Payment Pricing ─────────────────────────────────────
COST_PER_AI_TOKEN_UNITS=1    # 1 base unit per AI output token
MIN_PAYMENT_UNITS=100         # Minimum 1 PAIT (100 base units with 2 decimals)
MAX_TIMEOUT_SECONDS=300       # 5 min payment window

# ── PostgreSQL Database ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:1234@localhost:5432/payperai

# ── App ──────────────────────────────────────────────────────
APP_SECRET_KEY=replace-with-a-long-random-string-minimum-32-chars
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Creator Marketplace Encryption ───────────────────────────
# Generate with: python -c "import os; print(os.urandom(32).hex())"
API_KEY_ENCRYPTION_SECRET=your_32_byte_hex_encryption_secret_here

PLATFORM_BASE_URL=http://localhost:8000
