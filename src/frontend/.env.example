# ══════════════════════════════════════════════════════════════
# PayPerUseAI Frontend — Casper Network + x402
# ══════════════════════════════════════════════════════════════

# ── Backend API ───────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── Casper Network ────────────────────────────────────────────
VITE_CASPER_NETWORK=casper:casper-test

# ── CEP-18 Token (PAIT) ───────────────────────────────────────
# Copy these from backend/.env after token deployment
VITE_CEP18_CONTRACT_HASH=your_64_char_contract_package_hash_here
VITE_CEP18_TOKEN_NAME=PayAIToken
VITE_CEP18_TOKEN_SYMBOL=PAIT
VITE_CEP18_TOKEN_DECIMALS=2
VITE_CEP18_TOKEN_VERSION=1

# ── x402 Payment Settings ─────────────────────────────────────
VITE_MAX_TIMEOUT_SECONDS=300

# ── Casper Explorer ───────────────────────────────────────────
VITE_EXPLORER_URL=https://testnet.cspr.live